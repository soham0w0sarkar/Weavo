{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "NEXT_STATIC_EXPORT",
        "NEXT_PUBLIC_BASE_PATH",
        "NEXT_PUBLIC_WEAVO_WS_URL"
      ]
    },
    "build:pages": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["out/**"],
      "env": [
        "NEXT_STATIC_EXPORT",
        "NEXT_PUBLIC_BASE_PATH",
        "NEXT_PUBLIC_WEAVO_WS_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": ["coverage/**"]
    }
  }
}
