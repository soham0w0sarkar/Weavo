{
  "name": "@relay/client",
  "version": "1.0.0",
  "description": "Real-time collaborative text editing for the browser — bind a textarea, connect to a WebSocket room, edits sync automatically.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soham0w0sarkar/Relay.git",
    "directory": "packages/relay"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "bun test --preload ./test/setup.ts"
  },
  "dependencies": {
    "@relay/code": "workspace:*",
    "@relay/sync": "workspace:*",
    "@relay/transport": "workspace:*"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.10.6",
    "@repo/typescript-config": "workspace:*",
    "fast-check": "^4.6.0",
    "happy-dom": "^20.10.6",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  }
}
