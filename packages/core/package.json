{
  "name": "@weavo/core",
  "version": "2.0.0",
  "description": "CRDT core for Weavo collaborative text editing",
  "keywords": [
    "weavo",
    "crdt",
    "collaborative-editing",
    "text-editing",
    "operations",
    "replica",
    "skip-list"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soham0w0sarkar/Weavo.git",
    "directory": "packages/core"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "bun test"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.9.2",
    "bun-types": "^1.3.9",
    "fast-check": "^4.6.0",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  }
}
