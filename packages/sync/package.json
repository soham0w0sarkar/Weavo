{
  "name": "@weavo/sync",
  "version": "1.0.1",
  "description": "State-vector sync for Weavo CRDT operations",
  "keywords": [
    "weavo",
    "crdt",
    "sync",
    "state-vector",
    "collaborative-editing",
    "operations",
    "buffer"
  ],
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soham0w0sarkar/Weavo.git",
    "directory": "packages/sync"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "bun test"
  },
  "dependencies": {
    "@weavo/core": "^1.0.1"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "fast-check": "^4.6.0",
    "tsup": "^8.5.1",
    "typescript": "5.9.2"
  }
}
