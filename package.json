{
  "name": "Weavo",
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "prettier": "^3.7.4",
    "turbo": "^2.8.7",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.9",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "build:pages": "turbo run build:pages --filter=demo",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=@weavo/core --filter=@weavo/sync --filter=@weavo/transport --filter=@weavo/client && changeset publish",
    "tag-release": "bash scripts/tag-release.sh",
    "tag-demo": "bash scripts/tag-demo.sh"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
